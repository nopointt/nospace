":"/adv/news?tag=metrika","anchor":null,"label":"Больше новостей по Метрике","target":null,"rel":null,"nav_item":{"data":null},"metrika_goal":{"data":null},"icon":{"data":null}}}],"secondaryColorEnd":null},{"id":126,"__component":"v2.banner","title":"Метрика Про — специальный пакет для крупных бизнесов","subtitle":"Получите доступ к полным данным без семплирования, используйте расширенные лимиты и интеграцию с Yandex Cloud","image":{"src":"https://avatars.mds.yandex.net/get-adv/121152/2a000001928ecda8be38c9c2921260d17af3/orig","sources":[],"metaName":" "},"theme":"dark","buttonTheme":"ghost","variant":"violet","button":{"id":230,"url":"https://yandex.ru/project/metrica/pro","anchor":null,"label":"Подробнее","target":null,"rel":null,"nav_item":{"data":null},"metrika_goal":{"data":null},"icon":{"data":null}}},{"id":2230,"__component":"v2.card-edge","position":"start","primaryColor":"gray","secondaryColor":null,"components":[{"id":1946,"__component":"v2.h2","value":"Читайте также","variant":"title1","align":"left","anchor":null,"subtitle":null},{"id":75,"__component":"v2.article-feed","pageSize":8,"hideFilters":false,"cardBackgroundColor":"background_primary","feedType":"Carousel","productFilters":[{"id":1466,"product":{"data":{"id":2,"attributes":{"slug":"metrika","title":"Метрика","createdAt":"2022-11-30T12:13:08.703Z","updatedAt":"2024-09-19T04:32:09.830Z","locale":"ru-RU","icon":"https://avatars.mds.yandex.net/get-adv/60663/2a000001890dd3494b1db8f5d7546e668843/orig","localizations":{"data":[]}}}}}],"moreButton":{"id":1795,"url":null,"anchor":null,"label":"Смотреть все","target":null,"rel":null,"nav_item":{"data":{"id":207,"attributes":{"url":"/edu/materials/tag-metrika","title":"Яндекс Метрика","createdAt":"2023-03-28T12:52:22.474Z","updatedAt":"2023-03-28T12:52:22.474Z","locale":"ru-RU","parent":{"data":{"id":13,"attributes":{"url":"/edu/materials","title":"Полезные материалы","createdAt":"2023-01-27T03:44:16.835Z","updatedAt":"2023-09-19T10:34:08.616Z","locale":"ru-RU","parent":{"data":{"id":12,"attributes":{"url":"/edu","title":" Обучение","createdAt":"2023-01-27T03:43:46.295Z","updatedAt":"2023-09-14T11:32:56.715Z","locale":"ru-RU","parent":{"data":{"id":17,"attributes":{"url":"/","title":"Главная","createdAt":"2023-01-27T03:47:23.956Z","updatedAt":"2023-09-14T11:33:21.359Z","locale":"ru-RU","parent":{"data":null},"localizations":{"data":[]}}}},"localizations":{"data":[]}}}},"localizations":{"data":[]}}}},"localizations":{"data":[]}}}},"metrika_goal":{"data":null},"icon":{"data":null}},"categoryFilters":[]}],"secondaryColorEnd":null},{"id":108,"__component":"v2.accordions-list","title":"С чего начать","schemaType":null,"list":[{"id":144,"title":"Как зарегистрироваться в Яндекс Метрике и войти в личный кабинет?","content":"\u003cp\u003eВы\u0026nbsp;можете самостоятельно создать счётчик или \u003ca href=\"https://yandex.ru/project/freeservice/metrica\" target=\"_blank\"\u003eзаказать его создание и\u0026nbsp;настройку\u003c/a\u003e.\u003c/p\u003e\n\u003cp\u003eВот как создать счётчик самостоятельно.\u003c/p\u003e\n\u003cp\u003e\u003cstrong\u003eШаг 1. Зарегистрируйтесь на\u0026nbsp;сайте\u003c/strong\u003e \u003cstrong\u003eyandex.metrika.ru или авторизуйтесь на\u0026nbsp;нём.\u003c/strong\u003e Вход в\u0026nbsp;личный кабинет возможен только через Яндекс ID. Если он\u0026nbsp;у\u0026nbsp;вас уже есть, просто авторизуйтесь в\u0026nbsp;сервисе. В\u0026nbsp;случае если Яндекс ID пока нет, потребуется \u003ca href=\"https://passport.yandex.ru/passport?mode=register\" target=\"_blank\"\u003eрегистрация\u003c/a\u003e.\u003c/p\u003e\n\u003cp\u003eЕсли вы\u0026nbsp;уже используете Яндекс Директ или являетесь партнёром Яндекс Маркета, используйте тот\u0026nbsp;же логин, что и\u0026nbsp;в\u0026nbsp;этих сервисах, чтобы войти в\u0026nbsp;личный кабинет Метрики. Так вы\u0026nbsp;сможете быстро переходить из\u0026nbsp;одного сервиса в\u0026nbsp;другой.\u003c/p\u003e\n\u003cp\u003e\u003cstrong\u003eШаг 2. Создайте счётчик.\u003c/strong\u003e Нажмите \u0026laquo;\u003ca href=\"https://metrika.yandex.ru/add\" target=\"_blank\"\u003eДобавить счётчик\u003c/a\u003e\u0026raquo; и\u0026nbsp;выберите нужные настройки. Подробнее\u0026nbsp;\u0026mdash; \u003ca href=\"https://yandex.ru/support/metrica/general/creating-counter.html#creating-counter\" target=\"_blank\"\u003eв\u0026nbsp;\u003c/a\u003e\u003ca href=\"https://yandex.ru/support/metrica/general/creating-counter.html#creating-counter\" target=\"_blank\"\u003eинструкции\u003c/a\u003e.\u003c/p\u003e\n\u003cp\u003e\u003cstrong\u003eШаг 3. Установите счётчик на\u0026nbsp;сайт. \u003c/strong\u003eЯндекс Метрика поможет фиксировать действия пользователей на\u0026nbsp;сайте и\u0026nbsp;анализировать статистику в\u0026nbsp;отчётах. В\u0026nbsp;настройках во\u0026nbsp;вкладке \u0026laquo;Счётчик\u0026raquo; скопируйте код Яндекс Метрики и\u0026nbsp;вставьте его в\u0026nbsp;HTML-код всех страниц сайта. Рекомендуем разместить его как можно ближе к\u0026nbsp;началу страницы\u0026nbsp;\u0026mdash; от\u0026nbsp;этого зависит полнота и\u0026nbsp;корректность подсчёта данных.\u003c/p\u003e\n\u003cp\u003eСчётчик будет отображаться на\u0026nbsp;странице \u0026laquo;Мои счётчики\u0026raquo;. Убедиться, что всё настроено корректно, поможет проверка Метрики. Как её провести, рассказали \u003ca href=\"https://yandex.ru/support/metrica/general/check-counter.html\" target=\"_blank\"\u003eв\u0026nbsp;Справке\u003c/a\u003e.\u003c/p\u003e","image":null,"size":[],"cardSize":null,"caption":null},{"id":145,"title":"Какие задачи помогает решать Метрика рекламодателям и паблишерам?","content":"\u003cp\u003eЯндекс Метрика\u0026nbsp;\u0026mdash; универсальный сервис, который предлагает инструменты аналитики как для рекламодателей, так и\u0026nbsp;для владельцев контентных площадок.\u003c/p\u003e\n\u003cp\u003eС\u0026nbsp;помощью Метрики:\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003e\u003cstrong\u003eРекламодатели Яндекс Директа\u003c/strong\u003e \u003cstrong\u003eи\u0026nbsp;других рекламных систем\u003c/strong\u003e смогут оценить качество своего сайта и\u0026nbsp;особенности поведения посетителей на\u0026nbsp;нём, узнать, какие действия приводят к\u0026nbsp;покупке или другому целевому действию, проанализировать эффективность продвижения и\u0026nbsp;скорректировать настройки рекламной кампании так, чтобы она работала эффективнее. Подробнее\u0026nbsp;\u0026mdash; \u003ca href=\"https://yandex.ru/support/direct/statistics/metrika.html\" target=\"_blank\"\u003eв\u0026nbsp;Справке\u003c/a\u003e.\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eВладельцы медийных и\u0026nbsp;контентных проектов\u003c/strong\u003e смогут отслеживать метрики сайта (например, вовлечённость или доход) и\u0026nbsp;трафик в\u0026nbsp;реальном времени, анализировать эффективность контента, изучать поведение посетителей на\u0026nbsp;странице материала или рубрики и\u0026nbsp;принимать решения по\u0026nbsp;развитию контентного проекта. Подробнее\u0026nbsp;\u0026mdash; на\u0026nbsp;странице контентной аналитики.\u003c/li\u003e\u003c/ul\u003e","image":null,"size":[],"cardSize":null,"caption":null},{"id":146,"title":"Как настроить интеграцию Метрики с сайтом или CRM-системой?","content":"Вы\u0026nbsp;можете воспользоваться готовыми решениями в\u0026nbsp;каталоге интеграций Метрики. Они позволяют в\u0026nbsp;несколько кликов настроить нужную интеграцию с\u0026nbsp;сайтом, CRM-системой или коллтрекингом. \u003ca href=\"https://metrika.yandex.ru/marketplace\" target=\"_blank\"\u003eПосмотреть все интеграции\u003c/a\u003e","image":null,"size":[],"cardSize":null,"caption":null},{"id":147,"title":"Что такое Метрика Про?","content":"Метрика Про\u0026nbsp;\u0026mdash; это пакет для крупного бизнеса, который расширяет базовые возможности Яндекс Метрики. Он\u0026nbsp;позволяет работать с\u0026nbsp;большими данными в\u0026nbsp;интерфейсе Яндекс Метрики, создавать больше сегментов и\u0026nbsp;целей, а\u0026nbsp;также передавать данные в\u0026nbsp;Yandex Cloud в\u0026nbsp;реальном времени.","image":null,"size":[],"cardSize":null,"caption":null},{"id":148,"title":"Где можно узнать больше о Метрике и её возможностях?","content":"\u003cp\u003eПолучить ответы на\u0026nbsp;любые вопросы\u0026nbsp;\u0026mdash; от\u0026nbsp;\u0026laquo;Яндекс Метрика\u0026nbsp;\u0026mdash; что это?\u0026raquo; до\u0026nbsp;\u0026laquo;Какие решения предлагает Яндекс для аналитики?\u0026raquo;\u0026nbsp;\u0026mdash; помогут полезные материалы:\u003c/p\u003e\n\u003cul\u003e\n    \u003cli\u003e\u003ca href=\"/adv/news?tag=metrika\"\u003eНовости Яндекс Метрики\u003c/a\u003e. Последние обновления сервиса на\u0026nbsp;Портале Рекламы.\u003c/li\u003e\n    \u003cli\u003e\u003ca href=\"/adv/edu/materials/tag-metrika\"\u003eСтатьи и\u0026nbsp;гайды\u003c/a\u003e. Инструкции по\u0026nbsp;работе с\u0026nbsp;сервисом и\u0026nbsp;лайфхаки для аналитиков.\u003c/li\u003e\n    \u003cli\u003eКурс \u003ca href=\"/adv/edu/materials/metrika-start\"\u003e\u0026laquo;Основы работы с\u0026nbsp;Яндекс Метрикой\u0026raquo;\u003c/a\u003e. Всё о\u0026nbsp;том, как устроена Метрика,\u0026nbsp;\u0026mdash; обучение в\u0026nbsp;текстовом формате.\u003c/li\u003e\n    \u003cli\u003e\u003ca href=\"/adv/expert/materials/metrika\"\u003eМатериалы для подготовки к\u0026nbsp;сертификации\u003c/a\u003e. Полезные ссылки для специалистов, которые хотят проверить и\u0026nbsp;подтвердить свои знания.\u003c/li\u003e\n\u003c/ul\u003e","image":null,"size":[],"cardSize":null,"caption":null}]},{"id":4773,"__component":"v2.group-start","group":{"data":{"id":62,"attributes":{"slug":"-4,6,10,-4","createdAt":"2024-12-11T11:08:24.817Z","updatedAt":"2024-12-11T11:14:17.525Z","props":[{"id":60,"__component":"v2-grid.custom-grid","sm":[],"sl":["-2,3,6,-1"],"m":["-5,6,10,-3"],"l":["-5,6,10,-3"],"backgroundColor":"transparent"}]}}},"components":[{"id":1,"__component":"v2.link-button","variant":"primary","link":{"id":503,"url":"https://passport.yandex.ru/auth/list?retpath=https%3A%2F%2Fmetrika.yandex.ru","anchor":null,"label":"Созд