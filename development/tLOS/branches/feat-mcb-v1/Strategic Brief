<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Liquid Glass Strategic Brief</title>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com" rel="preconnect"/>
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#f2b90d",
                        "background-light": "#f8f8f5",
                        "background-dark": "#0a0a0f",
                        "glass-border": "rgba(255, 255, 255, 0.08)",
                        "glass-bg": "rgba(10, 10, 15, 0.6)",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    },
                    borderRadius: {"DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px"},
                },
            },
        }
    </script>
<style>
        /* Custom scrollbar for webkit */
        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background-color: rgba(255, 255, 255, 0.1);
            border-radius: 20px;
        }
        .liquid-glass {
            background: rgba(10, 10, 15, 0.6);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
        }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark font-display min-h-screen flex items-center justify-center p-4">
<!-- Main Container simulating the screen context -->
<div class="relative w-full max-w-md mx-auto">
<!-- Liquid Glass Card -->
<div class="liquid-glass rounded-xl overflow-hidden flex flex-col w-full max-w-[420px] mx-auto animate-fade-in">
<!-- Header -->
<header class="flex items-center justify-between px-5 py-4 border-b border-white/5">
<div class="flex items-center gap-3">
<span class="material-symbols-outlined text-white/40 text-[20px]">
                        radar
                    </span>
<span class="text-white/40 text-xs font-bold tracking-widest uppercase">Signal</span>
</div>
<div class="flex items-center gap-3">
<div class="flex items-center px-2 py-0.5 rounded bg-green-500/10 border border-green-500/20">
<span class="w-1.5 h-1.5 rounded-full bg-green-500 mr-2 animate-pulse"></span>
<span class="text-green-500 text-[10px] font-bold uppercase tracking-wider">In Progress</span>
</div>
<button class="text-white/40 hover:text-white transition-colors">
<span class="material-symbols-outlined text-[20px]">
                            close
                        </span>
</button>
</div>
</header>
<!-- Content Body -->
<div class="p-6 pb-2 flex flex-col gap-5">
<!-- Title Section -->
<div class="flex flex-col gap-1">
<h1 class="text-white text-xl font-bold leading-tight">
                        Блог отсутствует → нейровыдача не растёт
                    </h1>
</div>
<!-- Impact Metrics -->
<div class="flex items-center gap-3">
<div class="flex items-center px-2 py-0.5 rounded bg-red-500/10 border border-red-500/20">
<span class="text-red-500 text-[10px] font-bold uppercase tracking-wider">Critical</span>
</div>
<span class="text-red-400 font-mono font-bold text-lg tracking-tight">−₽52,000/mo</span>
</div>
<!-- Info Grid -->
<div class="flex flex-col gap-3 py-2">
<!-- Row 1 -->
<div class="grid grid-cols-[80px_1fr] items-start gap-4 text-sm">
<span class="text-white/40 font-medium">Отвечает:</span>
<div class="text-slate-200">
                            Артём + <span class="text-primary underline decoration-primary/30 underline-offset-2">Helga (vzletagency)</span>
</div>
</div>
<!-- Row 2 -->
<div class="grid grid-cols-[80px_1fr] items-center gap-4 text-sm">
<span class="text-white/40 font-medium">Срок:</span>
<span class="text-slate-200">15 марта 2026</span>
</div>
<!-- Row 3 -->
<div class="grid grid-cols-[80px_1fr] items-start gap-4 text-sm">
<span class="text-white/40 font-medium">Статус:</span>
<span class="text-slate-200 leading-snug">Создан блог-раздел, пишутся статьи</span>
</div>
</div>
<!-- Progress Section -->
<div class="mt-2 space-y-2">
<div class="flex justify-between items-end text-xs">
<span class="text-white/40 font-medium uppercase tracking-wider">Прогресс задачи</span>
<span class="text-primary font-mono font-bold">Day 12 / 45</span>
</div>
<div class="h-1 w-full bg-white/5 rounded-full overflow-hidden">
<div class="h-full bg-primary shadow-[0_0_10px_rgba(242,185,13,0.5)] rounded-full" style="width: 27%"></div>
</div>
</div>
</div>
<!-- Footer Action -->
<div class="p-6 pt-4">
<button class="w-full group relative overflow-hidden rounded-lg bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 transition-all duration-300 py-3 flex items-center justify-center gap-2">
<span class="relative z-10 text-white font-bold text-sm tracking-wide">Открыть SEO борд</span>
<span class="material-symbols-outlined relative z-10 text-white text-[16px] transition-transform group-hover:translate-x-1">
                        arrow_forward
                    </span>
<!-- Button Glow Effect -->
<div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 translate-x-[-100%] group-hover:translate-x-[100%]"></div>
</button>
</div>
</div>
<!-- Background Elements for context/depth -->
<div class="absolute -z-10 top-[-50px] right-[-50px] w-64 h-64 bg-primary/10 rounded-full blur-[80px] opacity-40 pointer-events-none"></div>
<div class="absolute -z-10 bottom-[-20px] left-[-20px] w-48 h-48 bg-purple-500/10 rounded-full blur-[60px] opacity-30 pointer-events-none"></div>
</div>
</body></html>