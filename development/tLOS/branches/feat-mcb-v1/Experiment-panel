<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Liquid Glass Experiment Panel</title>
<link href="https://fonts.googleapis.com" rel="preconnect"/>
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#135bec",
                        "background-light": "#f6f6f8",
                        "background-dark": "#0a0a0f", // Updated to match user request: #0a0a0f
                        "glass-border": "rgba(255, 255, 255, 0.08)",
                        "glass-bg": "rgba(20, 20, 25, 0.6)",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "2xl": "1rem", "full": "9999px" },
                    backdropBlur: {
                        'xs': '2px',
                    }
                },
            },
        }
    </script>
<style>
        /* Custom Liquid Glass Effects */
        .liquid-glass {
            background: rgba(16, 22, 34, 0.4); /* Slightly transparent dark base */
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-shadow: 
                0 4px 6px -1px rgba(0, 0, 0, 0.1), 
                0 2px 4px -1px rgba(0, 0, 0, 0.06),
                inset 0 1px 0 0 rgba(255, 255, 255, 0.05);
        }
        
        .liquid-glass-button {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.2s ease;
        }
        
        .liquid-glass-button:hover {
            background: rgba(255, 255, 255, 0.08);
            border-color: rgba(255, 255, 255, 0.2);
        }

        /* Ambient background glow for demo purposes */
        .ambient-glow {
            position: absolute;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(19, 91, 236, 0.15) 0%, rgba(10, 10, 15, 0) 70%);
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            z-index: 0;
            pointer-events: none;
        }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark min-h-screen flex items-center justify-center font-display overflow-hidden relative">
<!-- Ambient background element to show off glassmorphism -->
<div class="ambient-glow"></div>
<!-- Canvas Grid Background Pattern -->
<div class="absolute inset-0 z-0 opacity-[0.03]" style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 24px 24px;">
</div>
<!-- Main Component: Liquid Glass Experiment Panel -->
<main class="relative z-10 w-[380px] h-[520px] rounded-2xl liquid-glass flex flex-col overflow-hidden text-slate-100">
<!-- Header Section -->
<header class="flex items-center justify-between px-5 pt-5 pb-2">
<div class="flex items-center gap-3">
<div class="flex items-center gap-1.5 text-slate-400">
<span class="material-symbols-outlined text-[18px]">science</span>
<span class="text-xs font-semibold uppercase tracking-wider">Experiment</span>
</div>
<div class="flex items-center px-2 py-0.5 rounded-full bg-primary/20 border border-primary/30">
<span class="text-[10px] font-bold text-blue-300 leading-none">Running — Day 9/30</span>
</div>
</div>
<button class="text-slate-400 hover:text-white transition-colors p-1 -mr-1">
<span class="material-symbols-outlined text-[20px]">close</span>
</button>
</header>
<!-- Content Body -->
<div class="flex-1 px-5 flex flex-col gap-5 overflow-y-auto custom-scrollbar">
<!-- Title & Hypothesis -->
<div>
<h1 class="text-xl font-bold leading-tight text-white mb-2">FAQ Blocks on Geo-Pages</h1>
<p class="text-sm text-slate-400 leading-relaxed">
                    Hypothesis: Adding FAQ sections will increase neural search citations for geo-targeted queries.
                </p>
</div>
<!-- Metrics Grid -->
<div class="bg-slate-800/30 rounded-xl p-4 border border-white/5">
<div class="flex items-center justify-between mb-3">
<h3 class="text-xs font-bold text-slate-300 uppercase tracking-wide">Metrics</h3>
<span class="text-[10px] text-slate-500 font-mono">LIVE</span>
</div>
<div class="grid grid-cols-2 gap-4">
<!-- Column 1: Before -->
<div class="flex flex-col gap-1 border-r border-white/5 pr-2">
<span class="text-[10px] text-slate-500 font-medium mb-1">Before</span>
<div class="flex flex-col">
<span class="text-[11px] text-slate-400">Neural</span>
<span class="text-sm font-semibold text-slate-200">232 queries</span>
</div>
<div class="flex flex-col mt-1">
<span class="text-[11px] text-slate-400">Traffic</span>
<span class="text-sm font-semibold text-slate-200">1,840/wk</span>
</div>
</div>
<!-- Column 2: Now -->
<div class="flex flex-col gap-1 pl-1">
<span class="text-[10px] text-blue-400 font-medium mb-1">Now (Day 9)</span>
<div class="flex flex-col">
<span class="text-[11px] text-slate-400">Neural</span>
<div class="flex items-baseline gap-1">
<span class="text-sm font-semibold text-white">238</span>
<span class="text-[10px] text-green-400 font-medium">(+6)</span>
</div>
</div>
<div class="flex flex-col mt-1">
<span class="text-[11px] text-slate-400">Traffic</span>
<div class="flex items-baseline gap-1">
<span class="text-sm font-semibold text-white">1,910</span>
<span class="text-[10px] text-green-400 font-medium">(+70)</span>
</div>
</div>
</div>
</div>
<!-- Progress Bar -->
<div class="mt-4 pt-3 border-t border-white/5">
<div class="flex justify-between text-[10px] mb-1.5">
<span class="text-slate-400">Progress</span>
<span class="text-amber-400 font-mono">30%</span>
</div>
<div class="h-1 w-full bg-slate-700/50 rounded-full overflow-hidden">
<div class="h-full bg-amber-500 w-[30%] shadow-[0_0_10px_rgba(245,158,11,0.5)]"></div>
</div>
</div>
</div>
<!-- Expected Outcome & Confidence -->
<div class="flex flex-col gap-3 pb-2">
<div class="flex items-start gap-2">
<span class="material-symbols-outlined text-[16px] text-primary mt-0.5">flag</span>
<div>
<span class="text-[10px] uppercase text-slate-500 font-bold tracking-wide block mb-0.5">Expected Outcome</span>
<span class="text-sm text-slate-200 font-medium">+40 neural queries, +₽12,000/mo</span>
</div>
</div>
<div class="flex items-start gap-2 mt-1">
<span class="material-symbols-outlined text-[16px] text-slate-500 mt-0.5">analytics</span>
<div>
<span class="text-[10px] uppercase text-slate-500 font-bold tracking-wide block mb-0.5">Confidence</span>
<div class="flex flex-col gap-0.5">
<div class="flex items-center gap-1.5">
<span class="text-xs text-slate-300">Early signal:</span>
<span class="text-xs text-green-400 font-medium flex items-center gap-0.5">
<span class="material-symbols-outlined text-[12px]">check</span> positive
                                </span>
</div>
<div class="flex items-center gap-1.5">
<span class="text-xs text-slate-300">Statistical validity:</span>
<span class="text-xs text-slate-500 italic">insufficient — continue</span>
</div>
</div>
</div>
</div>
</div>
</div>
<!-- Footer Actions -->
<div class="p-5 mt-auto border-t border-white/5 bg-black/20 backdrop-blur-sm">
<div class="flex items-center justify-between gap-2">
<!-- Close Experiment (Red Outline) -->
<button class="flex-1 px-3 py-2 rounded-lg border border-red-500/30 text-red-400 hover:bg-red-500/10 text-xs font-semibold transition-all flex items-center justify-center gap-1.5 whitespace-nowrap">
<span class="material-symbols-outlined text-[14px]">stop_circle</span>
                    End
                </button>
<!-- Scale (Green Outline - Disabled) -->
<button class="flex-1 px-3 py-2 rounded-lg border border-green-500/20 text-green-500/40 cursor-not-allowed text-xs font-semibold flex items-center justify-center gap-1.5 whitespace-nowrap opacity-60" disabled="">
<span class="material-symbols-outlined text-[14px]">trending_up</span>
                    Scale
                </button>
<!-- Continue (Solid Blue) -->
<button class="flex-[1.5] px-4 py-2 rounded-lg bg-primary hover:bg-blue-600 text-white text-xs font-bold transition-all shadow-[0_0_15px_rgba(19,91,236,0.4)] flex items-center justify-center gap-1.5 whitespace-nowrap">
                    Continue 
                    <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
</button>
</div>
</div>
</main>
</body></html>