---
import BaseLayout from "@contexter/shared/layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Features from "../components/Features.astro";
import Comparison from "../components/Comparison.astro";
import FAQ from "../components/FAQ.astro";
import InstallCTA from "../components/InstallCTA.astro";

const title = "contexter-vault — redact secrets from Claude Code";
const description = "Local proxy that redacts API keys, tokens, and client credentials from Claude Code conversations before they leave your machine. Open source, zero dependencies, MIT.";
const canonicalURL = "https://vault.contexter.cc/";
---

<BaseLayout title={title} description={description} canonicalURL={canonicalURL}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "contexter-vault",
    description: "Local proxy that redacts secrets from Claude Code before they leave your machine.",
    applicationCategory: "DeveloperApplication",
    operatingSystem: "macOS, Linux, Windows",
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "USD",
    },
    softwareVersion: "0.2.0",
    license: "https://opensource.org/licenses/MIT",
    url: "https://vault.contexter.cc/",
    sameAs: ["https://github.com/nopointt/contexter-vault", "https://www.npmjs.com/package/contexter-vault"],
    author: {
      "@type": "Person",
      name: "nopoint",
      url: "https://github.com/nopointt",
    },
  }, null, 2)} />
  <Hero />
  <HowItWorks />
  <Features />
  <Comparison />
  <FAQ />
  <InstallCTA />
</BaseLayout>
