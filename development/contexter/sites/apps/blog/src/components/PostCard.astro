---
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"posts">;
  authorName: string;
}

const { post, authorName } = Astro.props;
const formattedDate = post.data.pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<article class="border border-[var(--color-border-subtle)] bg-[var(--color-bg-surface)] p-6 hover:bg-[var(--color-bg-elevated)] transition-colors">
  <a href={`/${post.slug}/`} class="block no-underline">
    <div class="flex items-center gap-4 mb-3">
      <time datetime={post.data.pubDate.toISOString()} class="font-mono text-xs text-[var(--color-text-tertiary)]">
        {formattedDate}
      </time>
      <span class="font-mono text-xs text-[var(--color-text-tertiary)]">·</span>
      <span class="font-mono text-xs text-[var(--color-text-tertiary)] lowercase">{authorName}</span>
    </div>
    <h2 class="font-mono text-xl text-[var(--color-text-primary)] lowercase mb-3">
      {post.data.title}
    </h2>
    <p class="font-sans text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4">
      {post.data.description}
    </p>
    {post.data.tags.length > 0 && (
      <div class="flex gap-2 flex-wrap">
        {post.data.tags.map((tag: string) => (
          <span class="font-mono text-xs text-[var(--color-accent)] border border-[var(--color-accent)] px-2 py-1 lowercase">
            {tag}
          </span>
        ))}
      </div>
    )}
  </a>
</article>
