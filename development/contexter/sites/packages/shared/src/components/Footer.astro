---
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-border-subtle)] bg-[var(--color-bg-canvas)] mt-16">
  <div class="max-w-[1280px] mx-auto px-6 py-6 flex items-center justify-between">
    <span class="font-mono text-xs text-[var(--color-text-tertiary)] lowercase">
      © {year} contexter.cc
    </span>
    <div class="flex items-center gap-6">
      <a href="https://contexter.cc" class="font-mono text-xs text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] lowercase">main</a>
      <a href="https://github.com/nopointt/contexter-vault" class="font-mono text-xs text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] lowercase">github</a>
    </div>
  </div>
</footer>
