{
  "name": "harkly-web",
  "type": "module",
  "scripts": {
    "dev": "vinxi dev --port 1420",
    "build": "vinxi build",
    "start": "vinxi start",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply KB_DB --local && wrangler d1 migrations apply AUTH_DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply KB_DB --remote && wrangler d1 migrations apply AUTH_DB --remote",
    "types": "wrangler types",
    "deploy": "wrangler pages deploy",
    "preview": "wrangler pages dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.3",
    "@solidjs/start": "^1.3.0",
    "aws4fetch": "^1.0.20",
    "better-auth": "^1.2.0",
    "better-auth-cloudflare": "^0.1.0",
    "drizzle-orm": "^0.45.0",
    "mammoth": "^1.12.0",
    "solid-js": "^1.9.5",
    "ulid": "^2.3.0",
    "unpdf": "^1.4.0",
    "vinxi": "^0.5.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250312.0",
    "@playwright/test": "^1.58.2",
    "@solidjs/testing-library": "^0.8.10",
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "drizzle-kit": "^0.31.4",
    "jsdom": "^29.0.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0",
    "wrangler": "^3.109.0"
  }
}
