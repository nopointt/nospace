# ============================================================
# nospace workspace — .gitignore
# ============================================================

# ------------------------------------------------------------
# CRITICAL: Secrets & Credentials (NEVER commit these)
# ------------------------------------------------------------
private_knowledge/context/longterm/
private_knowledge/context/current/
*.env
*.env.*
!*.env.example
*.key
*.pem
*.p12
*.pfx
*.secret
*.secrets
web3-seed-phrases*
*-seed-phrase*
*-mnemonic*

# ------------------------------------------------------------
# Runtime / Session State
# ------------------------------------------------------------
temp/
data/
# memory/ — tracked (private repo, needed for AI assistant context sync)

# ------------------------------------------------------------
# Build Artifacts
# ------------------------------------------------------------
# Rust
target/
*.rlib
*.rmeta
audit-report.json

# Node / Bun
node_modules/
dist/
build/
.next/
.nuxt/
*.tsbuildinfo

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/

# ------------------------------------------------------------
# OS / Editor Junk
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/
*.suo
*.user

# ------------------------------------------------------------
# Logs & Databases
# ------------------------------------------------------------
*.log
*.logs
log-raw*.md
*.sqlite
*.sqlite3
*.db

# ------------------------------------------------------------
# Claude / AI context caches
# ------------------------------------------------------------
.claude/cache/
*.jsonl

# ------------------------------------------------------------
# private_knowledge — selective exclusions
# ------------------------------------------------------------
private_knowledge/context/current/temp-mcp-tokens
private_knowledge/context/current/active-sessions.json
