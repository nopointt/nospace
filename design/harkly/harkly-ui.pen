            },
            {
              "type": "text",
              "id": "gHiK7",
              "name": "sec1Sub",
              "fill": "#777777",
              "content": "Three tempo registers: Presto (micro-feedback) · Andante (state-change) · Adagio (structural). Scale: proportional bar, 1ms ≈ 0.3px.",
              "fontFamily": "Inter",
              "fontSize": 11,
              "fontWeight": "normal"
            },
            {
              "type": "frame",
