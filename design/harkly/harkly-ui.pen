                {
                  "type": "text",
                  "id": "RS0kB",
                  "name": "rmTitle",
                  "fill": "#1C1C1C",
                  "content": "REDUCE MOTION — duration.none = 0ms",
                  "fontFamily": "Inter",
                  "fontSize": 12,
                  "fontWeight": "700",
                  "letterSpacing": 0.5
                },
                {
                  "type": "text",
                  "id": "o3wmM",
                  "name": "rmBody",
                  "fill": "#555555",
                  "textGrowth": "fixed-width",
                  "width": 900,
                  "content": "Use duration.none for prefers-reduced-motion: reduce. All animated transitions collapse to instant state change. Moholy-Nagy Finsternis principle (b07 P-08): silence is a scored event, not absence. The absence of motion is itself a compositional decision.",
                  "fontFamily": "Inter",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "UClg6",
                  "name": "rmCode",
                  "fill": "#888888",
                  "textGrowth": "fixed-width",
                  "width": 900,
                  "content": "@media (prefers-reduced-motion: reduce) { transition-duration: var(--duration-none); /* 0ms */ }",
                  "fontFamily": "Inter",
                  "fontSize": 10,
                  "fontWeight": "normal"
                }
              ]
            }
          ]
        },
