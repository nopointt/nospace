                  "id": "UClg6",
                  "name": "rmCode",
                  "fill": "#888888",
                  "textGrowth": "fixed-width",
                  "width": 900,
                  "content": "@media (prefers-reduced-motion: reduce) { transition-duration: var(--duration-none); /* 0ms */ }",
                  "fontFamily": "Inter",
                  "fontSize": 10,
                  "fontWeight": "normal"
                }
              ]
