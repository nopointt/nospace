NOMOS_ENV=dev
NOMOS_AUTH_TOKEN=<generate with: openssl rand -hex 16>
NOMOS_CORS_ORIGINS=["http://localhost:5173"]
NOMOS_BINANCE_TESTNET_API_KEY=
NOMOS_BINANCE_TESTNET_SECRET=
NOMOS_TELEGRAM_BOT_TOKEN=
NOMOS_TELEGRAM_CHAT_ID=
NOMOS_JOURNAL_PATH=/opt/nomos/memory/trading/journal.jsonl
NOMOS_PORTFOLIO_STATE_PATH=/opt/nomos/memory/trading/portfolio-state.json
NOMOS_HALT_FLAG_PATH=/opt/nomos/memory/trading/halt.flag
NOMOS_RUNNER_DIR=/opt/nomos/runner
NOMOS_RUNNER_CONTAINER_NAME=nomos-runner
NOMOS_LIVE_PRICE_POLL_SECONDS=5
NOMOS_RAG_ENABLED=false
